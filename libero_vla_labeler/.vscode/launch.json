{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Dataset (/home/tiandy/libero_100)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "args": [
                "--dataset_dir", "/home/tiandy/libero_100",
                "--suite", "libero_90",
                "--config", "${workspaceFolder}/config/config.yaml",
                "--output", "${workspaceFolder}/output"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Dry Run (gripper segmentation only)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/dry_run.py",
            "console": "integratedTerminal",
            "args": [
                "--folder", "/home/tiandy/libero_100",
                "--config", "${workspaceFolder}/config/config.yaml"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "HDF5 Frame Viewer",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/view_hdf5_frames.py",
            "console": "integratedTerminal",
            "args": [
                "--folder", "/home/tiandy/libero_100",
                "--config", "${workspaceFolder}/config/config.yaml"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Inspect Output (single JSON)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/inspect_output.py",
            "console": "integratedTerminal",
            "args": [
                "${workspaceFolder}/output/TASK_NAME_demo_0.json"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Inspect Output (all JSONs in output/)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/inspect_output.py",
            "console": "integratedTerminal",
            "args": [
                "${workspaceFolder}/output"
            ],
            "cwd": "${workspaceFolder}"
        }
    ]
}
